{
  "name": "antagna",
  "version": "0.0.0",
  "private": true,
  "description": "Antagna — internal operating system for Volt Production",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "db:gen": "pnpm --filter @antagna/db drizzle:generate",
    "db:push": "pnpm --filter @antagna/db drizzle:push",
    "db:studio": "pnpm --filter @antagna/db drizzle:studio",
    "db:seed": "pnpm --filter @antagna/db seed"
  },
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.0",
    "tsx": "^4.22.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
