# Antagna — environment variable template
# Copy this file to .env.local (or set in Vercel/Trigger.dev project settings).
# .env.local is gitignored. NEVER commit a filled-in .env file.
#
# For each var: where it comes from is noted in the comment.
# Some values exist already in Claude's memory (see ~/.claude/projects/.../memory/).

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=                # legacy JWT (eyJ...). Required for Storage REST API.
SUPABASE_SERVICE_ROLE_KEY_NEW=            # new format (sb_secret_...) — for non-Storage admin calls
SUPABASE_PROJECT_REF=                     # 20-char project ref (no protocol)
SUPABASE_ACCESS_TOKEN=                    # Personal Access Token (sbp_...) for Management API + migrations

# ─── Vercel (only needed for scripts that talk to api.vercel.com directly) ──
VERCEL_TOKEN=                             # vca_... bearer token
VERCEL_TEAM_ID=                           # team_...
VERCEL_PROJECT_ID=                        # prj_...

# ─── Anthropic ──────────────────────────────────────────────────────────────
# https://console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=                        # sk-ant-api03-...
# Models: locked per D-020 — DO NOT use anything else
ANTHROPIC_MODEL_OPUS=claude-opus-4-6
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001

# ─── OpenAI (embeddings only) ───────────────────────────────────────────────
# https://platform.openai.com → API keys. Restrict to "Embeddings: Write" scope.
OPENAI_API_KEY=                           # sk-proj-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Trigger.dev v3 ─────────────────────────────────────────────────────────
# https://cloud.trigger.dev → Project settings
TRIGGER_API_KEY=                          # tr_dev_... or tr_prod_...
TRIGGER_PROJECT_ID=
TRIGGER_API_URL=https://api.trigger.dev

# ─── Sentry ─────────────────────────────────────────────────────────────────
# https://sentry.io → Projects → DSN
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=                        # for source-map uploads in CI

# ─── Google Workspace / OAuth ───────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=                # https://<env>/auth/callback/google
GOOGLE_WORKSPACE_DOMAIN=voltsaudi.com

# ─── Email (decision pending — D-014, Pillar 8) ─────────────────────────────
RESEND_API_KEY=                           # if/when Resend chosen
EMAIL_FROM=                               # e.g. notifications@antagna.voltsaudi.com
EMAIL_SUBJECT_PREFIX=                     # e.g. [STAGING] for non-prod

# ─── WhatsApp (Baileys self-hosted gateway, D-023) ──────────────────────────
WHATSAPP_GATEWAY_URL=                     # e.g. https://wa-gw.antagna.me
WHATSAPP_GATEWAY_API_KEY=                 # shared secret between Antagna ↔ gateway

# ─── Cron / scheduled task auth ─────────────────────────────────────────────
CRON_SECRET=                              # 32-byte hex; rotate per env

# ─── Dafterah (finance — D-022, reference-only integration) ─────────────────
# No API integration yet; Antagna only stores reference numbers manually entered.
# Fields kept here for future activation.
DAFTERAH_API_BASE=
DAFTERAH_API_TOKEN=

# ─── Antagna's own MCP server (D-019) ───────────────────────────────────────
MCP_SERVER_TOKEN=                         # token clients use to act on Antagna
