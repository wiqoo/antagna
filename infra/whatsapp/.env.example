# Copy to .env (next to this file). Filled values keep the WhatsApp gateway
# bound to localhost only; the Cloudflare Tunnel below is what exposes it.

# Generate fresh — both random. openssl rand -hex 32
EVOLUTION_API_KEY=
EVOLUTION_DB_PASSWORD=

# The public URL that Evolution thinks it's running at. With Cloudflare
# Tunnel: https://whatsapp.antagna.me (or whatever subdomain you map).
# Local-only test: http://localhost:8080
EVOLUTION_PUBLIC_URL=http://localhost:8080

# Where Antagna receives inbound WhatsApp events. Vercel-hosted, so this
# is a stable public URL.
ANTAGNA_WEBHOOK_URL=https://antagna-v2.vercel.app/api/integrations/whatsapp/webhook
